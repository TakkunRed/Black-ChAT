# バックエンド種別: lmstudio または ollama
BACKEND_TYPE=lmstudio

# LLM サーバー接続設定（LM Studio: 1234 / Ollama: 11434）
LM_STUDIO_HOST=127.0.0.1
LM_STUDIO_PORT=1234

# API キー（LM Studio: 任意 / Ollama: 不要 → 空白でOK）
LM_STUDIO_API_KEY=

# アプリ認証設定
APP_USERNAME=admin
APP_PASSWORD=changeme

# サーバー設定
APP_HOST=0.0.0.0
APP_PORT=8021

# ── GraphRAG (LightRAG) 設定 ─────────────────────────────────────────────
# LM Studio にロードしているエンベディングモデル名（例: nomic-embed-text）
LIGHTRAG_EMBED_MODEL=nomic-embed-text
# エンベディングの次元数（モデルに合わせて変更: nomic-embed-text=768, text-embedding-ada-002=1536）
LIGHTRAG_EMBED_DIM=768
# デフォルト検索モード: naive / local / global / hybrid
LIGHTRAG_SEARCH_MODE=hybrid

UV_LINK_MODE=copy
